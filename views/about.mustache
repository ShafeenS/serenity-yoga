{{> head}}
{{> header}}

<div class="hero" style="padding:3rem 0">
  <div class="wrap">
    <h1>About Serenity Yoga</h1>
    <p>A welcoming space for movement, mindfulness and community.</p>
  </div>
</div>

<main>
  <div class="wrap">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start">
      <div class="section-card">
        <h2>Our Studio</h2>
        <p style="color:var(--muted);line-height:1.8;margin-top:0.75rem">
          Serenity Yoga Studio has been offering classes in yoga and mindfulness since 2015.
          We run a range of courses for all levels — from complete beginners finding their first
          downward dog, to experienced practitioners deepening their practice.
        </p>
        <p style="color:var(--muted);line-height:1.8;margin-top:0.75rem">
          Our instructors are fully qualified and bring years of experience across multiple
          yoga traditions including Vinyasa, Hatha and Yin.
        </p>
      </div>

      <div class="section-card">
        <h2>Find Us</h2>
        <dl class="kv" style="margin-top:0.75rem">
          <dt>Address</dt>   <dd>12 Tranquil Lane, Glasgow, G1 2YS</dd>
          <dt>Phone</dt>     <dd>0141 555 0199</dd>
          <dt>Email</dt>     <dd>hello@serenityyoga.local</dd>
          <dt>Weekdays</dt>  <dd>6:00am – 9:00pm</dd>
          <dt>Weekends</dt>  <dd>8:00am – 6:00pm</dd>
        </dl>
      </div>

      <div class="section-card">
        <h2>Our Classes</h2>
        <p style="color:var(--muted);line-height:1.8;margin-top:0.75rem">
          We offer two formats of course:
        </p>
        <ul style="color:var(--muted);line-height:2;margin-top:0.5rem;padding-left:1.25rem">
          <li><strong style="color:var(--ink)">Weekly Blocks</strong> — a series of weekly sessions running across several weeks, ideal for building a consistent practice</li>
          <li><strong style="color:var(--ink)">Weekend Workshops</strong> — intensive two-day events with multiple sessions, perfect for deepening focus on a particular theme</li>
        </ul>
        <div class="mt-2">
          <a href="/courses" class="btn primary">Browse Current Courses</a>
        </div>
      </div>

      <div class="section-card">
        <h2>Booking</h2>
        <p style="color:var(--muted);line-height:1.8;margin-top:0.75rem">
          Create a free account to book courses and sessions online. You can enrol in a full
          course or, where drop-in is available, book individual sessions.
        </p>
        <p style="color:var(--muted);line-height:1.8;margin-top:0.75rem">
          Spaces are confirmed immediately. If a course is full you will be placed on a
          waitlist and contacted when a space becomes available.
        </p>
        <div class="mt-2">
          <a href="/auth/register" class="btn primary">Register Free</a>
          <a href="/auth/login" class="btn" style="margin-left:0.5rem">Sign In</a>
        </div>
      </div>
    </div>
  </div>
</main>

{{> footer}}
